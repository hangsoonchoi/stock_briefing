# ============================================================
# 발행 방식 — web (기본, docs/ 폴더에 HTML) / email / both
# ============================================================
PUBLISH_MODE=web

# ============================================================
# 필수 키
# ============================================================

# Anthropic API Key (https://console.anthropic.com/ 에서 발급)
ANTHROPIC_API_KEY=sk-ant-...

# 이메일 발송 사용 시에만 필요 (PUBLISH_MODE=web 이면 안 채워도 됨)
# Gmail 앱 비밀번호 발급: https://myaccount.google.com/apppasswords
SENDER_EMAIL=
SENDER_APP_PASSWORD=
RECIPIENT_EMAIL=

# ============================================================
# 권장 키 (없으면 해당 모듈만 빈 값으로 처리됨)
# ============================================================

# FRED API 키 (https://fred.stlouisfed.org/docs/api/api_key.html — 무료, 즉시 발급)
# 거시 지표(Fed금리, CPI, 실업률 등) 가져올 때 필수
FRED_API_KEY=

# DART API 키 (https://opendart.fss.or.kr/intro/main.do — 무료, 즉시 발급)
# 한국 전자공시 가져올 때 필수
DART_API_KEY=

# ============================================================
# 선택 키 (텔레그램 알림 사용 시)
# ============================================================

# @BotFather 에서 봇 만들고 받는 토큰
TELEGRAM_BOT_TOKEN=

# 본인 chat_id (https://t.me/userinfobot 에서 확인 가능)
TELEGRAM_CHAT_ID=
